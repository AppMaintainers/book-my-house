<h1>Check Availability</h1>

<% if @react %>
  <div id="react-booking-form" data-react-component="BookingForm"></div>
<% else %>
  <%= form_with url: query_path, method: :post do |f| %>
    <fieldset role="group">
      <label>
        Year
        <%= f.number_field :year, value: Date.today.year, min: 2020, max: 2030 %>
      </label>
      <label>
        Month
        <%= f.number_field :month, value: Date.today.month, min: 1, max: 12 %>
      </label>
      <label>
        Day
        <%= f.number_field :day, value: Date.today.day, min: 1, max: 31 %>
      </label>
    </fieldset>
    <%= f.submit "Check" %>
  <% end %>
<% end %>
